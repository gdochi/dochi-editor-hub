{
  "id": "addon_script_library/common/1.0.0",
  "package": "addon_script_library",
  "version": "1.0.0",
  "editor": "npc_editor_addon",
  "mc_version": "common",
  "description": "NPC Editor add-on for browsing and installing Dochi script packages in-game.",
  "entry": "script_library.js",
  "install_dir": "dc_lib/addon_script_library",
  "player_scripts": [
    {
      "path": "script_library.js"
    }
  ],
  "files": [
    {
      "source": "script_library.js",
      "install_as": "script_library.js",
      "type": "script",
      "dependencies": [
        {
          "type": "package",
          "id": "npc_editor/common/1.0.0",
          "required": true,
          "note": "NPC Editor provides the Script Library launch button."
        },
        {
          "type": "mod",
          "id": "CNPCExtended",
          "required": true,
          "note": "Required for HTML GUI and browser event callbacks."
        }
      ]
    },
    {
      "source": "html/script_library.html",
      "install_as": "addon_script_library/script_library.html",
      "type": "html",
      "dependencies": []
    }
  ]
}
