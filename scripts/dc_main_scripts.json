{
  "schema": 1,
  "description": "Simple main-script overview. Only main scripts are listed; utility scripts describe what attaches to each main script.",
  "utility_root": "npc_util/common/1.0.0",
  "main_scripts": [
    {
      "id": "dialogue",
      "title": "Dialogue Trigger",
      "package": "dialogue",
      "script": "dc_dialogue_trigger.js",
      "role": "Runs dialogue trigger logic and opens the shared dialogue runtime.",
      "versions": [
        {
          "mc_version": "common",
          "version": "1.0.0",
          "manifest": "dialogue/common/1.0.0/manifest.json"
        }
      ],
      "utilities": [
        {
          "script": "dc_npc_core_module.js",
          "required": true,
          "load_order": 1,
          "role": "Core NPC/module helpers."
        },
        {
          "script": "dc_cfg_checker.js",
          "required": true,
          "load_order": 2,
          "role": "Config validation helpers."
        },
        {
          "script": "dc_util_common.js",
          "required": true,
          "load_order": 3,
          "role": "Shared utility helpers."
        },
        {
          "script": "dc_gui_runtime.js",
          "required": true,
          "load_order": 4,
          "role": "Shared HTML GUI bridge/runtime."
        },
        {
          "script": "dc_dialogue_util.js",
          "required": true,
          "load_order": 5,
          "role": "Dialogue data loading and rendering helpers."
        }
      ],
      "attachments": [
        {
          "type": "html",
          "path": "html/dc_util/dc_gui_runtime.html",
          "required": true
        },
        {
          "type": "json_dir",
          "path": "customnpcs/dc_data/dc_dialogues/",
          "required": true,
          "role": "Dialogue JSON root."
        }
      ]
    },
    {
