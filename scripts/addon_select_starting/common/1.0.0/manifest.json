{
  "id": "addon_select_starting/common/1.0.0",
  "package": "addon_select_starting",
  "version": "1.0.0",
  "editor": "dialogue_addon",
  "mc_version": "common",
  "description": "Dialogue JS action add-on for starter Pokemon selection",
  "entry": "select_starting.js",
  "install_dir": "dc_lib/addon_select_starting",
