{
  "id": "addon_select_starting/common/1.0.0",
  "package": "addon_select_starting",
  "version": "1.0.0",
  "editor": "dialogue_addon",
  "mc_version": "common",
  "description": "NPC and dialogue starter Pokemon selection add-on",
  "entry": "select_starting.js",
  "files": [
    {
      "source": "select_starting.js",
      "install_as": "select_starting.js",
      "type": "script",
      "dependencies": [
        {
          "type": "package",
          "id": "npc_util/common/1.0.0",
          "required": true,
          "note": "Requires dc_npc_core_module.js and dc_cfg_checker.js for dcE trigger/runtime loading."
        },
        {
          "type": "mod",
          "id": "cnpcextended",
          "required": true,
          "note": "Required for openHtmlGui and browser event callbacks."
        },
        {
          "type": "json_dir",
          "path": "customnpcs/dc_data/dc_starters/",
          "required": true,
          "note": "Starter selection JSON files live here."
        },
        {
          "type": "json_dir",
          "path": "customnpcs/dc_data/dc_installable_scripts/",
          "required": true,
          "note": "NPC Editor reads the starter selector dcE descriptor from here."
        }
      ]
    },
    {
      "source": "html/select_starting.html",
      "install_as": "addon_select_starting/select_starting.html",
      "type": "html",
      "dependencies": []
    },
    {
      "source": "dc_installable_scripts/dc_starter_select.json",
      "install_as": "dc_data/dc_installable_scripts/dc_starter_select.json",
      "type": "json",
      "dependencies": []
    },
    {
      "source": "dc_starters/sample_starters.json",
      "install_as": "dc_data/dc_starters/sample_starters.json",
      "type": "json",
      "dependencies": []
    }
  ]
}
