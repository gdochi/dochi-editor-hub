{
  "id": "npc_editor/common/1.0.0",
  "package": "npc_editor",
  "version": "1.0.0",
  "editor": "npc_editor",
  "mc_version": "common",
  "description": "NPC editor package sample shared for Forge and Fabric",
  "entry": "dc_npc_editor.js",
  "player_scripts": [
    "dc_npc_editor.js"
  ],
  "files": [
    {
      "source": "dc_npc_editor.js",
      "install_as": "dc_npc_editor.js",
      "dependencies": [
        {
          "type": "mod",
          "id": "CNPCExtended",
          "required": true,
          "note": "Required for HTML GUI and browser bridge calls."
        },
        {
          "type": "html",
          "path": "html/dc_npc_editor.html",
          "required": true
        },
        {
          "type": "directory",
          "path": "customnpcs/scripts/ecmascript/",
          "required": true,
          "note": "Scans installed ECMAScript and dc_lib scripts."
        },
        {
          "type": "json_dir",
          "path": "customnpcs/dc_data/dc_admins/",
          "required": true,
          "note": "Stores and reads NPC editor admin access data."
        },
        {
          "type": "json_dir",
          "path": "customnpcs/dc_data/dc_installable_scripts/",
          "required": true,
          "note": "NPC Editor reads installable dcE script descriptors from this directory."
        },
        {
          "type": "json_dir",
          "path": "customnpcs/dc_data/dc_lang/npc_editor/",
          "required": true,
          "note": "NPC editor language packs loaded by the HTML UI."
        }
      ]
    },
    {
      "source": "dc_npc_editor.html",
      "install_as": "dc_npc_editor.html",
      "type": "html",
      "dependencies": []
    },
    {
      "source": "dc_lang/npc_editor/en_us.json",
      "install_as": "dc_data/dc_lang/npc_editor/en_us.json",
      "type": "json",
      "dependencies": []
    },
    {
      "source": "dc_lang/npc_editor/ko_kr.json",
      "install_as": "dc_data/dc_lang/npc_editor/ko_kr.json",
      "type": "json",
      "dependencies": []
    },
    {
      "source": "dc_lang/npc_editor/ja_jp.json",
      "install_as": "dc_data/dc_lang/npc_editor/ja_jp.json",
      "type": "json",
      "dependencies": []
    },
    {
      "source": "dc_lang/npc_editor/zh_cn.json",
      "install_as": "dc_data/dc_lang/npc_editor/zh_cn.json",
      "type": "json",
      "dependencies": []
    },
    {
      "source": "dc_lang/npc_editor/ru_ru.json",
      "install_as": "dc_data/dc_lang/npc_editor/ru_ru.json",
      "type": "json",
      "dependencies": []
    }
  ]
}
