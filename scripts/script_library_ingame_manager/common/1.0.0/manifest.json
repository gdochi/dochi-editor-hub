{
  "id": "script_library_ingame_manager/common/1.0.0",
  "package": "script_library_ingame_manager",
  "version": "1.0.0",
  "editor": "script_library",
  "mc_version": "common",
  "description": "Script Library In-game Manager opened with the dce chat command.",
  "entry": "script_library_ingame_manager.js",
  "player_scripts": [
    {
      "path": "script_library_ingame_manager.js"
    }
  ],
  "files": [
