      "source": "script_library_ingame_manager.js",
      "install_as": "script_library_ingame_manager.js",
      "type": "script",
      "dependencies": [
        {
          "type": "mod",
          "id": "CNPCExtended",
          "required": true,
          "note": "Required for HTML GUI and browser bridge calls."
        },
        {
          "type": "mod",
          "id": "MCEF",
          "required": true,
          "note": "Required by CNPCExtended HTML GUI rendering."
        },
        {
          "type": "html",
          "path": "html/script_library_ingame_manager.html",
          "required": true
        },
        {
          "type": "json_dir",
          "path": "customnpcs/dc_data/dc_lang/script_library/",
          "required": true,
          "note": "Script Library language packs loaded by the in-game manager HTML UI."
        }
      ]
    },
    {
      "source": "script_library_ingame_manager.html",
      "install_as": "script_library_ingame_manager.html",
      "type": "html",
      "dependencies": []
    },
    {
      "source": "dc_lang/script_library/en_us.json",
      "install_as": "dc_data/dc_lang/script_library/en_us.json",
      "type": "json",
      "dependencies": []
    },
    {
      "source": "dc_lang/script_library/ko_kr.json",
      "install_as": "dc_data/dc_lang/script_library/ko_kr.json",
      "type": "json",
      "dependencies": []
    }
  ]
}
