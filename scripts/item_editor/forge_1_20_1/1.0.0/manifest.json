{
  "id": "item_editor/forge_1_20_1/1.0.0",
  "package": "item_editor",
  "version": "1.0.0",
  "editor": "item_editor",
  "mc_version": "forge_1_20_1",
  "description": "Item editor in-game CustomNPCs GUI script for Forge 1.20.1",
  "entry": "dc_item_editor.js",
  "files": [
    {
      "source": "dc_item_editor.js",
      "install_as": "dc_item_editor.js",
      "dependencies": [
        {
          "type": "json_dir",
          "path": "dc_data/dc_item/",
          "required": true,
          "note": "Default item JSON save/load root."
        },
        {
          "type": "json_dir",
          "path": "dc_data/dc_item/prefix/",
          "required": true,
          "note": "Default prefix preset directory."
        },
        {
          "type": "json",
          "path": "dc_data/dc_item/category_config.json",
          "required": false,
          "note": "Category configuration file created/read by the editor."
        },
        {
          "type": "json_dir",
          "path": "dc_data/dc_item/category_presets/",
          "required": false,
          "note": "Optional category preset directory used by preset import/export."
        }
      ]
    }
  ]
}
